# RedPill — server-only (never use NEXT_PUBLIC_ for these)
REDPILL_API_KEY=
REDPILL_MODEL=openai/gpt-oss-120b

# Chain — server-side contract writes
# RPC_URL is optional: auto-derived from NEXT_PUBLIC_ALCHEMY_API_KEY if omitted
# RPC_URL=
ADMIN_PRIVATE_KEY=

# Contract address — optional override (auto-detected from deployedContracts.ts if omitted)
# CONTRACT_ADDRESS=

# Frontend — public
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
